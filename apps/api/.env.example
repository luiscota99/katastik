# ──────────────────────────────────────────────────────────
# Katastik — API Backend
# Copiar este archivo a .env y rellenar los valores reales.
# El archivo .env NUNCA debe subirse a git.
# ──────────────────────────────────────────────────────────

# "demo"  → datos ficticios en RAM (modo por defecto / seguro para demos)
# "real"  → proxy a la API real del municipio
CATASTRO_SOURCE=demo

# URL base de la API catastral real (sin trailing slash)
CATASTRO_BASE_URL=http://134.255.227.95:6080

# Clave del municipio catastral (ej. 078 = San Cristóbal de las Casas)
CATASTRO_MUNICIPIO=078

# JWT de rol CAJA — usado para predios, predial, expedientes
CATASTRO_TOKEN_CAJA=

# JWT de rol NOTARIO — usado para firma digital (fallback a TOKEN_CAJA si vacío)
CATASTRO_TOKEN_NOTARIO=

# Puerto del servidor Express
PORT=8000

# ── Pagos: PorCobrar (cobranza REAL en stage) ──────────────────
# "porcobrar" para usar la integración real; dejar vacío para pago simulado
PAYMENTS_PROVIDER=porcobrar
PORCOBRAR_BASE_URL=https://stage.api.porcobrar.com
# JWT de la cuenta PorCobrar (stage o producción)
PORCOBRAR_JWT=
# URL pública (ej. ngrok) para registrar el webhook; el polling funciona sin esto
PORCOBRAR_WEBHOOK_PUBLIC_URL=

# ── Posteo al padrón municipal ─────────────────────────────────
# false = SIMULADO (no afecta datos reales del municipio)
# true  = real (requiere contrato `encoded` activo con el municipio)
CATASTRO_POST_PAYMENT=false

# ── Cincel (firma digital + NOM-151 REAL) ──────────────────────
CINCEL_BASE_URL=https://api.cincel.digital/v3
# Correo de la cuenta Cincel
CINCEL_EMAIL=
# UUID del equipo en Cincel (Settings → Team)
CINCEL_TEAM_UUID=
# UUID de la carpeta donde se suben los documentos
CINCEL_FOLDER_UUID=
# JWT obtenido vía OTP — renovar desde UI si expira: POST /api/cincel/refresh-jwt
# Plan free: sin expiración fija pero puede invalidarse. Plan Pro: usar PAT permanente.
CINCEL_JWT=
