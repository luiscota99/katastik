# Modo de datos: 'api' (Express backend) o 'mock' (JSON estáticos del /public/demo/)
VITE_CATASTRO_MODE=api

# URL base del backend (solo necesario cuando frontend y backend están en servicios separados)
# Vacío = usa el proxy nginx interno (docker-compose) o el proxy de Vite (dev local)
# Ej. en EasyPanel/Railway/Render con servicios separados:
# VITE_API_URL=https://katastik-back.tu-dominio.com
VITE_API_URL=
